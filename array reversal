#include <stdio.h>
#include <stdlib.h>

int main() {
    int num, *arr, i;
    
    // Read the size of the array
    if (scanf("%d", &num) != 1) return 1;

    // Dynamically allocate memory for the array
    arr = (int*) malloc(num * sizeof(int));
    
    // Read the array elements
    for(i = 0; i < num; i++) {
        scanf("%d", &arr[i]);
    }

    /* Logic to reverse the array */
    // We swap the i-th element from start with the i-th from end
    for (i = 0; i < num / 2; i++) {
        int temp = arr[i];
        arr[i] = arr[num - i - 1];
        arr[num - i - 1] = temp;
    }

    // Print the reversed array
    for(i = 0; i < num; i++) {
        printf("%d ", arr[i]);
    }
    
    // Free the allocated memory
    free(arr);
    
    return 0;
}
