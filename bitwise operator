#include <stdio.h>

void calculate_the_maximum(int n, int k) {
    int max_and = 0;
    int max_or = 0;
    int max_xor = 0;

    // Nested loops to find all pairs (i, j)
    for (int i = 1; i <= n; i++) {
        for (int j = i + 1; j <= n; j++) {
            
            // Bitwise AND
            int current_and = i & j;
            if (current_and < k && current_and > max_and) {
                max_and = current_and;
            }

            // Bitwise OR
            int current_or = i | j;
            if (current_or < k && current_or > max_or) {
                max_or = current_or;
            }

            // Bitwise XOR
            int current_xor = i ^ j;
            if (current_xor < k && current_xor > max_xor) {
                max_xor = current_xor;
            }
        }
    }

    // Print results in the required order
    printf("%d\n%d\n%d\n", max_and, max_or, max_xor);
}

int main() {
    int n, k;
    
    // Read n and k from input
    scanf("%d %d", &n, &k);
    
    calculate_the_maximum(n, k);
    
    return 0;
}
