#include <stdio.h>
#include <stdlib.h>

int main() {
    int n, *arr;

    printf("Enter number of elements to allocate: ");
    scanf("%d", &n);

    // Dynamically allocate memory using malloc
    arr = (int*)malloc(n * sizeof(int));

    if (arr == NULL) {
        printf("Memory allocation failed!\n");
        return 1;
    }

    for (int i = 0; i < n; i++) {
        arr[i] = i + 1;
        printf("%d ", arr[i]);
    }

    free(arr); // Always free memory you allocated!
    return 0;
}
