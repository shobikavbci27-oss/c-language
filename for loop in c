#include <stdio.h>

int main() {
    int a, b;
    // Read the starting and ending integers
    scanf("%d\n%d", &a, &b);

    // Loop from a to b (inclusive)
    for (int n = a; n <= b; n++) {
        if (n >= 1 && n <= 9) {
            // Print English word for numbers 1 to 9
            if (n == 1) printf("one\n");
            else if (n == 2) printf("two\n");
            else if (n == 3) printf("three\n");
            else if (n == 4) printf("four\n");
            else if (n == 5) printf("five\n");
            else if (n == 6) printf("six\n");
            else if (n == 7) printf("seven\n");
            else if (n == 8) printf("eight\n");
            else printf("nine\n");
        } 
        else if (n > 9) {
            // Check if n is even or odd for numbers > 9
            if (n % 2 == 0) {
                printf("even\n");
            } else {
                printf("odd\n");
            }
        }
    }

    return 0;
}
