#include <stdio.h>

/* 
  Function to find the maximum of four integers.
  It compares the numbers step-by-step to find the largest.
*/
int max_of_four(int a, int b, int c, int d) {
    int max = a;

    if (b > max) max = b;
    if (c > max) max = c;
    if (d > max) max = d;

    return max;
}

int main() {
    int a, b, c, d;
    
    // Reading four integers from input
    scanf("%d %d %d %d", &a, &b, &c, &d);
    
    // Calling the function and storing the result
    int ans = max_of_four(a, b, c, d);
    
    // Printing the largest number
    printf("%d", ans);
    
    return 0;
}
