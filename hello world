#include <stdio.h>
#include <string.h>

int main() {
    char s[100]; // Declare a character array to hold the input string

    /* Read a full line of input from stdin.
       %[^\n] tells scanf to read everything until a newline.
       %*c reads and discards the newline character itself. */
    scanf("%[^\n]%*c", s);
  	
    // Print "Hello, World!" on the first line
    printf("Hello, World!\n");
    
    // Print the input string stored in 's' on the second line
    printf("%s\n", s);

    return 0;
}
