#include <stdio.h>

int main() {
    char ch;
    char s[100];
    char sen[100];

    // 1. Read a single character
    scanf("%c", &ch);

    // 2. Read a single string (word)
    scanf("%s", s);

    // 3. Clear the buffer and read a full sentence
    // The "\n" inside scanf consumes the newline left by the previous word
    scanf("\n"); 
    scanf("%[^\n]%*c", sen);

    // Output the results
    printf("%c\n", ch);
    printf("%s\n", s);
    printf("%s\n", sen);

    return 0;
}
