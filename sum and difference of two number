#include <stdio.h>

int main() {
    int n, m;
    float x, y;

    // Read two integers from the first line
    scanf("%d %d", &n, &m);
    
    // Read two floats from the second line
    scanf("%f %f", &x, &y);

    // Print sum and difference of integers
    printf("%d %d\n", n + m, n - m);

    // Print sum and difference of floats rounded to one decimal place
    // %.1f ensures the output has exactly one digit after the decimal
    printf("%.1f %.1f\n", x + y, x - y);

    return 0;
}
